{
  "name": "@myczh/project-brain",
  "version": "0.0.6",
  "description": "Project memory and execution context engine for AI coding agents",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/packages/core/src/index.d.ts",
      "import": "./dist/packages/core/src/index.js"
    },
    "./protocol": {
      "types": "./dist/packages/protocol/src/index.d.ts",
      "import": "./dist/packages/protocol/src/index.js"
    },
    "./core": {
      "types": "./dist/packages/core/src/index.d.ts",
      "import": "./dist/packages/core/src/index.js"
    },
    "./infra-fs": {
      "types": "./dist/packages/infra-fs/src/index.d.ts",
      "import": "./dist/packages/infra-fs/src/index.js"
    },
    "./mode-embedded": {
      "types": "./dist/packages/mode-embedded/src/index.d.ts",
      "import": "./dist/packages/mode-embedded/src/index.js"
    }
  },
  "bin": {
    "project-brain": "./dist/packages/app/src/cli.js"
  },
  "files": [
    "dist/packages/app",
    "dist/packages/core",
    "dist/packages/infra-fs",
    "dist/packages/mode-embedded",
    "dist/packages/protocol",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "verify:protocol": "tsx -e \"import('./packages/protocol/src/index.ts').then(()=>console.log('protocol ok'))\"",
    "verify:core": "tsx -e \"import('./packages/core/src/index.ts').then(()=>console.log('core ok'))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "context",
    "project-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myczh-1/project-brain-mcp.git"
  },
  "homepage": "https://github.com/myczh-1/project-brain-mcp#readme",
  "bugs": {
    "url": "https://github.com/myczh-1/project-brain-mcp/issues"
  }
}
