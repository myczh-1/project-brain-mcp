{
  "name": "@myczh/project-brain",
  "version": "0.0.3",
  "description": "Project memory and execution context engine for AI coding agents",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/packages/mode-service/src/index.d.ts",
      "import": "./dist/packages/mode-service/src/index.js"
    },
    "./core-protocol": {
      "types": "./dist/packages/core-protocol/src/index.d.ts",
      "import": "./dist/packages/core-protocol/src/index.js"
    },
    "./mode-embedded": {
      "types": "./dist/packages/mode-embedded/src/index.d.ts",
      "import": "./dist/packages/mode-embedded/src/index.js"
    },
    "./mode-service": {
      "types": "./dist/packages/mode-service/src/index.d.ts",
      "import": "./dist/packages/mode-service/src/index.js"
    },
    "./runtime": {
      "types": "./dist/packages/runtime/src/index.d.ts",
      "import": "./dist/packages/runtime/src/index.js"
    },
    "./context": {
      "types": "./dist/packages/context/src/index.d.ts",
      "import": "./dist/packages/context/src/index.js"
    },
    "./transport-http": {
      "types": "./dist/packages/transport-http/src/index.d.ts",
      "import": "./dist/packages/transport-http/src/index.js"
    },
    "./transport-mcp": {
      "types": "./dist/packages/transport-mcp/src/index.d.ts",
      "import": "./dist/packages/transport-mcp/src/index.js"
    }
  },
  "bin": {
    "project-brain": "./dist/packages/mode-service/src/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch packages/app/src/serverMain.ts",
    "dev:http": "tsx watch packages/app/src/serverMain.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "http",
    "mcp",
    "ai",
    "context",
    "project-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myczh-1/project-brain-mcp.git"
  },
  "homepage": "https://github.com/myczh-1/project-brain-mcp#readme",
  "bugs": {
    "url": "https://github.com/myczh-1/project-brain-mcp/issues"
  }
}
